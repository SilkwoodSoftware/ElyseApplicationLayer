# Production Environment Configuration Template
# Copy this file to .env on the production server and update values

# Database Configuration
DB_TYPE=mssql
DB_HOST=YOUR_SQL_SERVER_HOST
DB_PORT=1433
DB_NAME=Elyse_DB
DB_SYNCHRONIZE=false
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# Authentication Configuration
# Set USE_KCD=true for production domain environment with Kerberos Constrained Delegation
# This enables user impersonation - SQL Server sees the authenticated end user, not the service account
USE_KCD=true

# Server Configuration
# Production: Use http://0.0.0.0:5000 to accept connections from frontend VM
# This binds to all network interfaces, allowing the frontend VM to connect
SERVER_URLS=http://0.0.0.0:5000

# Application Role Passwords (must match SQL Server application roles)
CONFIGURATOR_PASSWORD=YOUR_CONFIGURATOR_PASSWORD
READER_PASSWORD=YOUR_READER_PASSWORD
REVIEWER_PASSWORD=YOUR_REVIEWER_PASSWORD
CONTROLLER_PASSWORD=YOUR_CONTROLLER_PASSWORD
EDITOR_PASSWORD=YOUR_EDITOR_PASSWORD
AUTHORISER_PASSWORD=YOUR_AUTHORISER_PASSWORD